        "detail.ubicacion" => pick(locale, "Ubicación", "Location"),
        "detail.desempeno" => pick(locale, "Desempeño", "Performance"),
        "detail.permisos" => pick(locale, "Permisos", "Permissions"),
        "detail.skills" => pick(locale, "Skills", "Skills"),
        // Tree
