        "form.estado" => pick(locale, "Estado", "Status"),
        "form.desempeno" => pick(locale, "Desempeño", "Performance"),
        "form.notas" => pick(locale, "Notas", "Notes"),
        "form.notas.ph" => pick(locale, "Notas internas…", "Internal notes…"),
        "form.depto" => pick(locale, "Departamento", "Department"),
