        "form.reporta" => pick(locale, "Reporta a", "Reports to"),
        "form.reporta.none" => pick(locale, "— Nadie —", "— Nobody —"),
        "form.pais" => pick(locale, "País", "Country"),
        "form.provincia" => pick(locale, "Provincia", "Province"),
        "form.ciudad" => pick(locale, "Ciudad", "City"),
        "form.permisos" => pick(locale, "Permisos", "Permissions"),
        "form.skills" => pick(locale, "Skills", "Skills"),
        "form.save" => pick(locale, "Guardar", "Save"),
        "form.cancel" => pick(locale, "Cancelar", "Cancel"),
        "form.back" => pick(locale, "← Atrás", "← Back"),
        "form.next" => pick(locale, "Siguiente →", "Next →"),
        "form.finish" => pick(locale, "Finalizar", "Finish"),
        "form.required" => pick(locale, "Nombre y email son obligatorios.", "Name and email are required."),
        _ => key,
    }
}
