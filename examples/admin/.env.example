# Admin ABM showcase — environment variables.
#
# Copy to `.env` and adjust. `fitz run` reads real OS env vars; for local
# dev without Docker, export these (or point DATABASE_URL at your Postgres).
#
# In docker-compose.yml the app service already gets these values wired to
# the `db` service — you only need this file for local `fitz run`.

# Postgres connection string. The default assumes a `fitz`/`fitz` role and
# a `fitz_admin` database on localhost. Adjust to your local Postgres.
DATABASE_URL=postgres://fitz:fitz@localhost:5432/fitz_admin?sslmode=disable

# HMAC secret for the session JWT. CHANGE THIS in production — anyone who
# knows it can forge admin sessions.
JWT_SECRET=demo-admin-secret-cambiame-en-produccion-por-favor

# The demo admin (admin@fitz.dev / admin1234) is seeded by db/init.sql,
# not by env vars. Change it there (and re-run the SQL) before any real use.
